<!-- app/views/offers/show.html.erb -->
 <% content_for :meta_title, "#{@drawer.name} is on #{DEFAULT_META["meta_product_name"]}" %>

<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-12 col-md-10 col-lg-8">

      <div class="card shadow-sm border-0 rounded-4">
        <div class="card-body p-4 p-md-5">

          <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="fw-bold mb-0"><%= @drawer.name %></h2>
            <%= link_to "Add Item", new_drawer_clothing_item_path(@drawer), class: "btn custom-btn" %>
          </div>

          <% if @clothing_items.empty? %>
                <p class="text-white">No clothing items yet. Add your first one!</p>
              <% else %>
                <div class="row row-cols-2 row-cols-sm-3 row-cols-md-4 g-3">
                  <% @clothing_items.each do |item| %>
                    <div class="col ">
                      <%= link_to clothing_item_path(item), class: "card h-100 border-0 shadow-sm text-decoration-none btn custom-btn" do %>
                        <% if item.item_image.attached? %>
                          <%= image_tag item.item_image, class: "img-tm card-img-top" %>
                        <% else %>
                          <div class="card-img-top d-flex align-items-center justify-content-center bg-light no-image-placeholder">
                            <span class="text-muted">No image</span>
                          </div>
                        <% end %>
                        <% if item.care_summary.present? %>
                          <div class="card-body p-2">
                            <ul class="care-icon-list list-unstyled text-white small mb-0">
                              <% care_icons_for(item).zip(item.care_summary.split(",").map(&:strip).reject(&:blank?)).each do |icon, line| %>
                                <% next unless line %>
                                <li class="care-icon-item d-flex align-items-center gap-1 mb-1">
                                  <span class="care-icon <%= 'care-icon--disallowed' unless icon[:allowed] %>">
                                    <%= icon[:svg].html_safe %>
                                    <% unless icon[:allowed] %>
                                      <svg class="care-icon__cross" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="20" height="20"
                                           stroke-width="2" stroke-linecap="round">
                                        <line x1="4" y1="4" x2="20" y2="20"/>
                                      </svg>
                                    <% end %>
                                  </span>
                                  <span class="care-icon-label">
                                    <%= line.sub(/\A./, &:upcase) %>
                                  </span>
                                </li>
                              <% end %>
                            </ul>
                          </div>
                        <% end %>
                      <% end %>
                    </div>
                  <% end %>
                </div>
              <% end %>
          <% if @drawer.instructions.present? %>
            <div class="drawer-instructions mt-4 p-3 rounded">
              <h6 class="fw-semibold mb-1">Washing Instructions</h6>
              <div class="text-white"><%= simple_format @drawer.instructions %></div>
              <div class="d-flex justify-content-end mt-2">
              <%= button_to chats_path, method: :post, params: { drawer_id: @drawer.id }, class: "btn p-0 border-0 bg-transparent flex-shrink-0" do %>
                <div class="card andrew-card border-0 shadow-sm text-center p-2">
                  <div class="card-body p-1 d-flex align-items-center gap-2">
                    <div class="chat-bubble">
                      <p class="text-white andrew-text mb-0">Hi, I'm Andrew.<br>Any question?</p>
                    </div>
                    <div class="andrew-emoji">🤖</div>
                  </div>
                </div>
              <% end %>
              </div>
            </div>
          <% end %>

        </div>
      </div>

    </div>
  </div>
</div>
