<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-12 col-md-10 col-lg-8">

      <div class="card shadow-sm border-0 rounded-4">
        <div class="card-body p-4 p-md-5">

          <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="fw-bold mb-0"><%= @chat.drawer.name %></h2>
            <% if @chat.drawer.name.present? %>
              <%= link_to drawer_path(@chat.drawer), class: "btn custom-btn" do %>
                <i class="fa-regular fa-circle-left"></i>
                <%= @chat.drawer.name %>
              <% end %>
            <% end %>
          </div>

          <!-- Messages container -->
          <% if @chat.messages.any? %>
            <div id="messages" class="bg-light p-4 rounded-4 mb-4" style="max-height: 60vh; overflow-y: auto;">

              <% @chat.messages.each do |message| %>

                <% if message.role == "user" %>
                  <div class="d-flex justify-content-end mb-3">
                    <div class="text-black px-4 py-1 rounded-pill shadow-sm text-center" style="background-color: #f5f5f5; max-width: 70%;">
                      <%= raw(render_markdown(message.content)) %>
                    </div>
                  </div>

                <% elsif message.role == "assistant" %>
                  <div class="d-flex justify-content-start mb-3">
                    <div class="text-black bg-white px-4 py-2 rounded-4 shadow-sm border" style="max-width: 70%;">
                      <%= raw(render_markdown(message.content)) %>
                    </div>
                  </div>
                <% end %>

              <% end %>

            </div>
          <% end %>

          <div id="new_message_container">
            <%= simple_form_for [@chat, @message] do |f| %>

              <div class="row g-2 align-items-end">

                <div class="col">
                  <%= f.input :content,
                    label: false,
                    placeholder: "Ask something about #{@chat.drawer.name}...",
                    input_html: { class: "form-control rounded-pill px-4 py-2" } %>
                </div>

                <div class="col-auto">
                  <%= f.button :submit, "Ask Andrew",
                    class: "btn custom-btn rounded-pill px-4" %>
                </div>

              </div>

            <% end %>
          </div>

        </div>
      </div>

    </div>
  </div>
</div>
