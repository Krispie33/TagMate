<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-12 col-md-10 col-lg-8">

      <div class="card shadow-sm border-0 rounded-4">
        <div class="card-body p-4 p-md-5">

          <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="fw-bold mb-0"><%= @drawer.name %></h2>
            <%= link_to "Add Item", new_drawer_clothing_item_path(@drawer), class: "btn custom-btn" %>
          </div>

          <% if @clothing_items.empty? %>
                <p class="text-white">No clothing items yet. Add your first one!</p>
              <% else %>
                <div class="row row-cols-2 row-cols-sm-3 row-cols-md-4 g-3">
                  <% @clothing_items.each do |item| %>
                    <div class="col ">
                      <%= link_to clothing_item_path(item), class: "card h-100 border-0 shadow-sm text-decoration-none btn custom-btn" do %>
                        <% if item.item_image.attached? %>
                          <%= image_tag item.item_image, class: "img-tm card-img-top" %>
                        <% else %>
                          <div class="card-img-top d-flex align-items-center justify-content-center bg-light" style="height: 160px;">
                            <span class="text-muted">No image</span>
                          </div>
                        <% end %>
                        <% if item.care_summary.present? %>
                          <div class="card-body p-2">
                            <ul class="card-text text-white small mb-0 ps-3">
                              <% item.care_summary.split(",").map(&:strip).reject(&:blank?).each do |line| %>
                                <li><%= line %></li>
                              <% end %>
                            </ul>
                          </div>
                        <% end %>
                      <% end %>
                    </div>
                  <% end %>
                </div>
              <% end %>
          <% if @drawer.instructions.present? %>
            <div class="mt-4 p-3 rounded" style="background-color: rgba(255,255,255,0.15);">
              <h6 class="fw-semibold mb-1">Washing Instructions</h6>
              <div class="text-white"><%= simple_format @drawer.instructions %></div>
              <div class="d-flex justify-content-end mt-2">
              <%= button_to chats_path, method: :post, params: { drawer_id: @drawer.id }, class: "btn p-0 border-0 bg-transparent flex-shrink-0" do %>
                <div class="card andrew-card border-0 shadow-sm text-center p-2">
                  <div class="card-body p-1 d-flex align-items-center gap-2">
                    <div class="chat-bubble">
                      <p class="text-white mb-0" style="font-size: 0.78rem; line-height: 1.3;">Hi, I'm Andrew.<br>How can I help?</p>
                    </div>
                    <div style="font-size: 2rem;">🤖</div>
                  </div>
                </div>
              <% end %>
              </div>
            </div>
          <% end %>

        </div>
      </div>

    </div>
  </div>
</div>
