<div class="landing-page d-flex flex-column">

  <!-- Hero Image -->
  <div class="landing-hero">
    <%= image_tag "TagMate_landing.png",
        class: "landing-hero-image",
        alt: "TagMate illustration" %>
  </div>

  <!-- Content -->
  <div class="landing-content text-center text-white d-flex flex-column justify-content-between">
  <div></div> <!-- spacer -->

  <div class="landing-inner mx-auto">
    <h1 class="landing-title">Your laundry, decoded.</h1>

    <% if user_signed_in? %>
      <p class="landing-welcome">
        Welcome back, <%= current_user.username %>
      </p>

      <div class="d-grid gap-3">
        <%= link_to "Start scanning", scan_path, class: "btn landing-cta" %>
      </div>

      <p class="landing-helper">
        Snap a label and get simple care instructions.
      </p>
    <% else %>
      <div class="d-grid gap-2 mt-3">
        <%= link_to "Login", new_user_session_path, class: "btn landing-cta" %>
        <%= link_to "Sign up", new_user_registration_path, class: "btn landing-cta-outline" %>
      </div>

      <p class="landing-helper">
        Learn what every laundry symbol means in seconds.
      </p>
    <% end %>
  </div>

  <div style="height: 40px;"></div> <!-- bottom spacing -->
