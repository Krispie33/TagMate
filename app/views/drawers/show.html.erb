<div class="max-w-4xl mx-auto p-6">
  <div class="flex items-center justify-between mb-6">
    <h1 class="text-2xl font-bold"><%= @drawer.name %></h1>
    <%= link_to "Add New Item", new_drawer_clothing_item_path(@drawer), class: "bg-blue-600 text-black px-4 py-2 rounded hover:bg-blue-700" %>
  </div>

  <% if @clothing_items.empty? %>
    <p class="text-gray-500">No clothing items yet. Add your first one!</p>
  <% else %>
    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-4">
      <% @clothing_items.each do |item| %>
        <%= link_to clothing_item_path(item), class: "bg-white rounded-lg shadow" do %>
          <% if item.item_image.attached? %>
            <%= image_tag item.item_image, class: "w-full h-40 object-cover" %>
          <% else %>
            <div class="w-full h-40 bg-gray-100 flex items-center justify-center">No image</div>
          <% end %>
          <div class="p-3">
            <% if item.care_summary.present? %>
              <p class="text-xs text-gray-600 line-clamp-2"><%= item.care_summary %></p>
            <% end %>
          </div>
        <% end %>
      <% end %>
    </div>
  <% end %>
</div>
