<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-12 col-md-10 col-lg-8">

      <div class="card shadow-sm border-0 rounded-4">
        <div class="card-body p-4 p-md-5">

          <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="fw-bold mb-0">My Clothes</h2>
            <% unless @drawer %>
              <%= link_to "Add New Item", scan_path, class: "btn custom-btn" %>
            <% end %>
          </div>

          <% if @clothing_items.empty? %>
            <p class="text-white">No clothing items yet. Add your first one!</p>
          <% else %>
            <div class="row row-cols-2 row-cols-sm-3 row-cols-md-4 g-3">
              <% @clothing_items.each do |item| %>
                <div class="col">
                  <div class="position-relative">
                    <%= link_to clothing_item_path(item), class: "card h-100 border-0 shadow-sm text-decoration-none btn custom-btn" do %>
                      <% if item.item_image.attached? %>
                        <%= image_tag item.item_image, class: "img-tm card-img-top" %>
                      <% else %>
                        <div class="card-img-top d-flex align-items-center justify-content-center bg-light" style="height: 160px;">
                          <span class="text-muted">No image</span>
                        </div>
                      <% end %>
                      <div class="card-body p-2">
                        <% if item.care_summary.present? %>
                          <p class="card-text text-white small"><%= item.care_summary %></p>
                        <% end %>
                        <% if item.drawer.present? %>
                          <p class="card-text text-white small"><%= item.drawer.name %></p>
                        <% end %>
                      </div>
                    <% end %>
                    <%= button_to clothing_item_path(item), method: :delete,
                          data: { turbo_confirm: "Delete this item?" },
                          class: "position-absolute bottom-0 end-0 m-2 btn btn-sm btn-light text-danger rounded-circle p-1 shadow-sm border-0" do %>
                      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M3 6h18M8 6V4h8v2M19 6l-1 14H6L5 6" />
                      </svg>
                    <% end %>
                  </div>
                </div>
              <% end %>
            </div>
          <% end %>

        </div>
      </div>

    </div>
  </div>
</div>
