
<div class="container mt-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0">Your Drawers</h1>
  </div>

  <% if @drawers.empty? %>
    <div class="text-center py-5 text-muted">
      <p class="fs-5">No drawers yet.</p>
    </div>
  <% else %>
    <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 g-4">
      <% @drawers.each do |drawer| %>
        <div class="col">
          <%= link_to drawer, class: "text-decoration-none" do %>
            <div class="card h-100 shadow-sm">
              <div class="card-body">
                <h5 class="card-title"><%= drawer.name %></h5>
                <p class="card-text text-muted small"><%= drawer.clothing_items.count %> items</p>
              </div>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>
  <% end %>
</div>
