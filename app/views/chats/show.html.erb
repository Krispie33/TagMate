<%= turbo_stream_from @chat %>
<div class="container pt-2 pb-5">
  <div class="row justify-content-center">
    <div class="col-12 col-md-10 col-lg-8">

      <div class="card shadow-sm border-0 rounded-4">
        <div class="card-body p-4 p-md-5">
          <%= link_to drawer_path(@chat.drawer), class: "d-inline-flex align-items-center gap-1 text-decoration-none mb-3 text-white" do %>
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
              <path fill-rule="evenodd" d="M15 8a.5.5 0 0 0-.5-.5H2.707l3.147-3.146a.5.5 0 1 0-.708-.708l-4 4a.5.5 0 0 0 0 .708l4 4a.5.5 0 0 0 .708-.708L2.707 8.5H14.5A.5.5 0 0 0 15 8"/>
            </svg>
            Back
          <% end %>
          <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="fw-bold mb-0"><%= @chat.drawer.name %></h2>
          </div>

          <!-- Messages container -->
          <% if @chat.messages.any? %>
            <div id="messages" class="p-1 rounded-4 mb-4" data-controller="scroll"
              data-action="turbo:before-stream-render@document->scroll#messagesChanged"
              style="background-color: #088395; max-height: 60vh; overflow-y: auto;">
              <% @chat.messages.each do |message| %>
                <%=render "messages/message", message: message  %>
              <% end %>
            </div>
          <% end %>

          <div id="new_message_container">
            <%= render "messages/form", chat: @chat, message: Message.new  %>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
