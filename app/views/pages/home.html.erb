<div class="landing-page d-flex flex-column vh-100 overflow-hidden">

  <div class="w-100 p-0">
    <%= image_tag "TagMate_square.png",
        class: "w-100 d-block",
        style: "object-fit: cover;",
        alt: "TagMate illustration" %>
  </div>

  <div class="landing-content text-center text-white flex-grow-1 d-flex flex-column p-4">

    <div class="landing-inner mx-auto w-100">
      <h1 class="landing-title mt-5 fw-bold">Your laundry, decoded.</h1>

      <% if user_signed_in? %>
        <p class="landing-welcome mt-1 opacity-75 fs-6">
          Welcome back, <strong><%= current_user.username %></strong>
        </p>

        <div class="flex-grow-1"></div>
          <div class="d-grid gap-3 mt-extra">
            <%= link_to "Start scanning", scan_path, class: "btn btn-light landing-cta py-3 fw-bold" %>
          </div>


        <p class="landing-helper mt-3 small opacity-75 px-3">
          Snap a label and get simple care instructions.
        </p>
      <% else %>
        <div class="d-grid gap-3 mt-extra">
          <%= link_to "Login", new_user_session_path, class: "btn btn-light landing-cta py-3 fw-bold" %>
          <%= link_to "Sign up", new_user_registration_path, class: "btn btn-outline-light py-3 fw-bold" %>
        </div>
      <% end %>
    </div>

  </div>
</div>
