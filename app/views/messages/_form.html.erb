<%= form_with url: chat_messages_path(chat), model: message, local: true,
      html: { multipart: true } do |f| %>

  <% if message.errors.any? %>
    <div class="alert alert-danger">
      <ul class="mb-0">
        <% message.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <%= f.text_area :content,
        placeholder: "Ask about washing instructions, or describe the item…",
        rows: 2,
        class: "form-control mb-2",
        required: true %>

  <div class="d-flex align-items-center gap-2">
    <label class="btn btn-outline-secondary btn-sm mb-0" title="Attach a care label photo">
      📎 Upload tag image
      <%= f.file_field :file, accept: "image/*", class: "d-none" %>
    </label>

    <span id="file-name-preview" class="text-muted small"></span>

    <%= f.submit "Send", class: "btn btn-primary btn-sm ms-auto" %>
  </div>
<% end %>

<script>
  document.addEventListener("DOMContentLoaded", function () {
    const fileInput = document.querySelector("input[type='file']");
    const preview = document.getElementById("file-name-preview");
    if (fileInput && preview) {
      fileInput.addEventListener("change", function () {
        preview.textContent = fileInput.files[0]?.name ?? "";
      });
    }
  });
</script>
