<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-12 col-md-10 col-lg-8">

      <div class="card shadow-sm border-0 rounded-4">
        <div class="card-body p-4 p-md-5">

          <h2 class="text-center fw-bold mb-3">Create Your Profile</h2>
          <p class="text-center text-muted mb-4">
            Select your washing machine
          </p>

          <%= form_with model: @profile do |f| %>

            <% if @profile.errors.any? %>
              <div class="alert alert-danger" role="alert">
                <ul class="mb-0">
                  <% @profile.errors.full_messages.each do |msg| %>
                    <li><%= msg %></li>
                  <% end %>
                </ul>
              </div>
            <% end %>

            <!-- Profile Name -->
            <div class="mb-3 text-center">
              <%= f.label :name, "Profile Name", class: "form-label fw-semibold" %>
              <%= f.text_field :name,
                    class: "form-control mx-auto",
                    style: "max-width: 250px;",
                    maxlength: 20 %>
            </div>

            <%= f.fields_for :machines do |m| %>

              <div data-controller="machine-select"
                   data-machine-select-models-value="<%= @machine_models.to_json %>">

                <!-- Brand -->
                <div class="mb-3 text-center">
                  <%= m.label :brand, "Machine Brand", class: "form-label fw-semibold" %>
                  <%= m.select :brand, @machine_brands,
                        { prompt: "Select brand" },
                        class: "form-select mx-auto",
                        style: "max-width: 250px;",
                        data: { machine_select_target: "brand", action: "change->machine-select#updateModels" } %>
                </div>

                <!-- Model -->
                <div class="mb-4 text-center">
                  <%= m.label :model, "Machine Model", class: "form-label fw-semibold" %>
                  <%= m.select :model, [],
                        { prompt: "Select model" },
                        class: "form-select mx-auto",
                        style: "max-width: 250px;",
                        data: { machine_select_target: "model" } %>
                </div>

              </div>

            <% end %>

            <!-- Buttons -->
            <div class="d-flex justify-content-center gap-3 mt-4">
              <%= f.submit "Create Profile", class: "btn custom-btn" %>
            </div>

          <% end %>

          <hr>

          <h3 class="fw-bold mb-4">Profiles</h3>

          <% @profiles.each do |p| %>
            <div class="mb-4 p-3 rounded" style="background-color: rgba(255,255,255,0.15);">

              <div class="form-check">
                <%= radio_button_tag :selected_profile, p.id, false, class: "form-check-input" %>
                <%= label_tag "selected_profile_#{p.id}", p.name, class: "form-check-label fw-semibold" %>
              </div>

              <ul class="mt-2">
                <% p.machines.each do |m| %>
                  <li><%= m.brand %> - <%= m.model %></li>
                <% end %>
              </ul>

              <%= button_to profile_path(p),
                    method: :delete,
                    data: { turbo_confirm: "Are you sure?" },
                    class: "btn custom-btn mt-2",
                    form: { style: "display:inline;" } do %>
                Delete
              <% end %>


            </div>
          <% end %>

        <div class="d-flex justify-content-end mt-4">
          <form action="<%= clothing_items_path %>"
            method="get"
            id="next-form"
            data-turbo="false">
            <button type="submit" class="btn custom-btn" id="next-btn">Next</button>
          </form>
        </div>



      <div id="machine-data" data-models='<%= @machine_models.to_json %>'></div>

      <script>
        document.getElementById("next-form").addEventListener("submit", (event) => {
          const radios = document.querySelectorAll('input[name="selected_profile"]');
          const selected = document.querySelector('input[name="selected_profile"]:checked');
          if (radios.length === 0) {
            event.preventDefault();
            alert("Please create a profile first before continuing.");
          } else if (!selected) {
            event.preventDefault();
            alert("Please select a profile before continuing.");
          }
        });
      </script>



      </div>
      </div>
    </div>
  </div>
</div>
