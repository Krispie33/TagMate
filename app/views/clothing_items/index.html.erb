<div class="max-w-4xl mx-auto p-6">
  <div class="flex items-center justify-between mb-6">
    <h1 class="text-2xl font-bold text-white">My Clothes</h1>
    <% unless @drawer %>
      <%= link_to "Add New Item", scan_path, class: "bg-blue-600 text-white px-4 py-2 rounded hover:bg-blue-700 text-decoration-none" %>
    <% end %>
  </div>

  <% if @clothing_items.empty? %>
    <p class="text-gray-500">No clothing items yet. Add your first one!</p>
  <% else %>
    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-4">
      <% @clothing_items.each do |item| %>
        <div class="relative">
          <%= link_to clothing_item_path(item), class: "bg-white rounded-lg shadow hover:shadow-md transition overflow-hidden text-decoration-none block" do %>
            <% if item.item_image.attached? %>
              <%= image_tag item.item_image, class: "img-tm" %>
            <% else %>
              <div class="w-full h-40 bg-gray-100 flex items-center justify-center text-gray-400 text-sm">No image</div>
            <% end %>
            <div class="p-3 space-y-1">
              <% if item.care_summary.present? %>
                <p class="text-xs text-white"><%= item.care_summary %></p>
              <% end %>
              <% if item.drawer.present? %>
                <p class="text-xs text-white"><%= item.drawer.name %></p>
              <% end %>
            </div>
          <% end %>
          <%= button_to clothing_item_path(item), method: :delete,
                data: { turbo_confirm: "Delete this item?" },
                class: "absolute bottom-2 right-2 bg-white bg-opacity-80 hover:bg-red-100 text-red-500 rounded-full p-1 shadow leading-none border-0" do %>
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 6h18M8 6V4h8v2M19 6l-1 14H6L5 6" />
            </svg>
          <% end %>
        </div>
      <% end %>
    </div>
  <% end %>
</div>
