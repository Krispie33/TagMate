<div class="container py-5" style="max-width: 520px;">
  <h2 class="mb-1 text-center">Scan a Care Label</h2>
  <p class="text-muted text-center mb-4">Upload a photo of a clothing tag to analyse the care instructions.</p>

  <%= form_with url: chat_messages_path(@chat), local: true, html: { multipart: true } do |f| %>

    <div class="mb-3">
      <%= f.label :file, "Care label photo", class: "form-label fw-semibold" %>
      <%= f.file_field :file, accept: "image/*", class: "form-control", required: true,
            data: { preview_target: "input" } %>
    </div>

    <div id="image-preview-container" class="mb-3 d-none text-center">
      <img id="image-preview" src="#" alt="Preview" class="img-fluid rounded-3 shadow-sm" style="max-height: 260px;" />
    </div>

    <div class="mb-3">
      <%= f.label :content, "Notes (optional)", class: "form-label fw-semibold" %>
      <%= f.text_area :content,
            placeholder: "e.g. wool jumper, black jeans…",
            rows: 2,
            class: "form-control" %>
    </div>

    <%= f.submit "Analyse Tag", class: "btn btn-primary w-100" %>

  <% end %>
</div>

<script>
  document.addEventListener("DOMContentLoaded", function () {
    const input   = document.querySelector("input[type='file']");
    const preview = document.getElementById("image-preview");
    const container = document.getElementById("image-preview-container");

    input.addEventListener("change", function () {
      const file = input.files[0];
      if (!file) return;
      preview.src = URL.createObjectURL(file);
      container.classList.remove("d-none");
    });
  });
</script>
