<div class="container pt-2 pb-5">
  <div class="row justify-content-center">
    <div class="col-12 col-md-10 col-lg-8">

      <div class="card shadow-sm border-0 rounded-4">
        <div class="card-body p-4 p-md-5">

          <%= link_to drawer_path(@clothing_item.drawer), class: "d-inline-flex align-items-center gap-1 text-decoration-none mb-3 text-white" do %>
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
              <path fill-rule="evenodd" d="M15 8a.5.5 0 0 0-.5-.5H2.707l3.147-3.146a.5.5 0 1 0-.708-.708l-4 4a.5.5 0 0 0 0 .708l4 4a.5.5 0 0 0 .708-.708L2.707 8.5H14.5A.5.5 0 0 0 15 8"/>
            </svg>
            Back
          <% end %>
          <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="fw-bold mb-0"><%= @clothing_item.name.presence || "Clothing item" %></h2>
          </div>

          <div class="row g-3 mb-4">
            <div class="col-6">
              <h6 class="fw-semibold text-white mb-2">Garment</h6>
              <% if @clothing_item.item_image.attached? %>
                <%= image_tag @clothing_item.item_image, class: "img-tm w-100 rounded-3" %>
              <% else %>
                <div class="d-flex align-items-center justify-content-center bg-light rounded-3" style="height: 160px;">
                  <span class="text-muted">No image</span>
                </div>
              <% end %>
            </div>
            <div class="col-6">
              <h6 class="fw-semibold text-white mb-2">Care Label</h6>
              <% if @clothing_item.tag_image.attached? %>
                <%= image_tag @clothing_item.tag_image, class: "img-tm w-100 rounded-3" %>
              <% else %>
                <div class="d-flex align-items-center justify-content-center bg-light rounded-3" style="height: 160px;">
                  <span class="text-muted">No image</span>
                </div>
              <% end %>
            </div>
          </div>

          <% if @clothing_item.care_summary.present? %>
            <div class="mt-4 p-3 rounded" style="background-color: rgba(255,255,255,0.15);">
              <h6 class="fw-semibold mb-2">How to wash this item</h6>
              <ul class="list-unstyled text-white small mb-0">
                <li><span class="fw-medium">Wash at:</span> <%= @clothing_item.wash_temp.present? ? "#{@clothing_item.wash_temp}°C" : "Cold / hand wash" %></li>
                <li><span class="fw-medium">Bleach:</span> <%= @clothing_item.bleach_allowed ? "Allowed" : "Do not bleach" %></li>
                <li><span class="fw-medium">Tumble dry:</span> <%= @clothing_item.tumble_dry ? "Allowed" : "Do not tumble dry" %></li>
                <li><span class="fw-medium">Iron:</span> <%= @clothing_item.iron_allowed ? "Allowed" : "Do not iron" %></li>
                <li><span class="fw-medium">Dry clean:</span> <%= @clothing_item.dry_clean ? "Yes" : "No" %></li>
              </ul>
            </div>

            <% if @clothing_item.drawer&.instructions.present? %>
              <div class="mt-3 p-3 rounded" style="background-color: rgba(255,255,255,0.15);">
                <h6 class="fw-semibold mb-1">Washing instructions for this drawer</h6>
                <div class="text-white small"><%= simple_format @clothing_item.drawer.instructions %></div>
              </div>
            <% end %>
          <% else %>
            <p class="text-white">Care instructions have not been processed yet.</p>
          <% end %>

        </div>
      </div>

    </div>
  </div>
</div>
